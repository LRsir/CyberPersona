# 赛博女友模式本地配置示例
# 复制为 .env.cyber-gf 后按需修改

# ========== Xiaomi MiMo TTS ==========
# 用于：赛博女友语音生成（本地执行层）
# 请填写你自己的 Xiaomi/OpenAI-compatible TTS endpoint
XIAOMI_BASE_URL=https://your-mimo-base-url.example/v1
XIAOMI_API_KEY=your_mimo_api_key_here
XIAOMI_TTS_MODEL=mimo-v2.5-tts
XIAOMI_TTS_VOICE=茉莉
XIAOMI_TTS_FORMAT=mp3

# ========== Local paths ==========
CYBER_GF_STATE_FILE=/root/.openclaw/workspace/.cyber-gf-state.json
CYBER_GF_HISTORY_FILE=/root/.openclaw/workspace/.cyber-gf-history.json
CYBER_GF_TTS_OUTPUT_DIR=/root/.openclaw/workspace/tts-cyber-gf

# ========== Debug ==========
# 普通模式请保持 false
# 设为 true 后，可通过 debug-last 查看最近一轮的调试信息
CYBER_GF_DEBUG=false
CYBER_GF_DEBUG_TTS=false
