# CyberPersona 配置示例
# 复制为 .env.cyber-gf 并填入真实值

# ========== Xiaomi MiMo TTS ==========
XIAOMI_BASE_URL=your_mimo_base_url_here
XIAOMI_API_KEY=your_xiaomi_api_key_here

# ========== Image API ==========
# 使用同一个 Xiaomi key，或单独配置
IMAGE_API_KEY=your_image_api_key_here
IMAGE_API_BASE=your_image_api_base_here

# ========== Telegram ==========
# 你的 Telegram chat ID（用于发送语音/图片等）
TELEGRAM_CHAT_ID=your_chat_id_here
